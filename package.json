{
  "name": "pumpfun-claims-bot",
  "version": "1.0.0",
  "description": "PumpFun on-chain intelligence — Telegram feed + MCP server for AI assistants. Query token data, GitHub social fee claims, creator profiles, and more.",
  "type": "module",
  "license": "MIT",
  "author": "nirholas",
  "repository": {
    "type": "git",
    "url": "https://github.com/nirholas/pumpfun-claims-bot.git"
  },
  "homepage": "https://github.com/nirholas/pumpfun-claims-bot#mcp-server",
  "bugs": {
    "url": "https://github.com/nirholas/pumpfun-claims-bot/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pumpfun",
    "solana",
    "claims",
    "telegram",
    "bot",
    "defi",
    "on-chain",
    "ai",
    "claude",
    "copilot"
  ],
  "bin": {
    "pumpfun-claims-bot": "dist/mcp-stdio.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp-stdio.js",
    "mcp:dev": "tsx src/mcp-stdio.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.35.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
