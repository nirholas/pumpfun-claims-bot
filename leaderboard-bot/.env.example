# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Channel to post leaderboards to (@channel_name or numeric -100xxx ID)
CHANNEL_ID=

# Solana RPC HTTP endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Additional fallback RPC endpoints (comma-separated)
# SOLANA_RPC_URLS=https://rpc1.example.com,https://rpc2.example.com

# Solana WebSocket endpoint (auto-derived from SOLANA_RPC_URL if not set)
# SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# GitHub personal access token — raises rate limit from 60 to 5000 req/hr
# GITHUB_TOKEN=ghp_...

# Leaderboard schedule: daily | weekly | both (default: daily)
# LEADERBOARD_SCHEDULE=daily

# UTC hour to post the leaderboard (0-23, default: 12)
# LEADERBOARD_HOUR=12

# Number of developers to show on the leaderboard (default: 10)
# LEADERBOARD_TOP_N=10

# Minimum SOL earned to appear on the leaderboard (default: 0)
# LEADERBOARD_MIN_SOL=0

# Polling interval in seconds when WebSocket is unavailable (default: 30)
# POLL_INTERVAL_SECONDS=30

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Directory for persisted leaderboard data (default: ./data)
# DATA_DIR=./data
